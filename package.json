{
  "name": "smart-page-translator",
  "displayName": "Smart Page Translator",
  "description": "Translate text in editor from English to Chinese",
  "version": "0.2.0",
  "publisher": "843773493",
  "icon": "asset/icon.png",
  "homepage": "https://github.com/843773493/smartpagetranslator",
  "keywords": [
    "vscode",
    "translator",
    "translation",
    "bing",
    "chinese"
  ],
  "author": "843773493",
  "repository": {
    "type": "git",
    "url": "https://github.com/843773493/smartpagetranslator.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:smartPageTranslator.translate",
    "onCommand:smartPageTranslator.extractAstOutline"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartPageTranslator.translate",
        "title": "Translate to Chinese",
        "icon": "$(file-text)"
      },
      {
        "command": "smartPageTranslator.extractAstOutline",
        "title": "复制代码结构上下文",
        "category": "Smart Page Translator"
      }
    ],
    "menus": {
      "editor/context/copy": [
        {
          "command": "smartPageTranslator.extractAstOutline",
          "when": "editorTextFocus && resourceExtname =~ /\\.(js|jsx|mjs|cjs|ts|tsx|py)$/"
        }
      ],
      "editor/title": [
        {
          "command": "smartPageTranslator.translate",
          "group": "navigation",
          "title": "Translate to Chinese (Create zh-CN file)"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Smart Page Translator",
      "properties": {
        "smartPageTranslator.concurrency": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of concurrent chunk translations."
        },
        "smartPageTranslator.maxChunk": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Maximum chunk length (in characters) when splitting text for translation. Default is 1000."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package": "npm run compile && node ./scripts/package-vsix.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "eslint": "^8.56.0",
    "typescript": "^5.9.3",
    "vsce": "^2.10.0"
  },
  "dependencies": {
    "bing-translate-api": "^3.0.1"
  },
  "files": [
    "scripts/**/*"
  ]
}
